	"sections": [
		{
			"id": "intensifiers",
			"title": "Intensifiers",
			"description": "Words that modify the degree of adjectives — note whether they go before or after",
			"colorKey": "intensifier",
			"words": {
				"rất": {
					"meaning": "Very (before adj)",
					"notes": [
						"BEFORE the adjective: 'rất đẹp' (very beautiful).",
						"The most neutral and common intensifier."
					]
				},
				"hơi": {
					"meaning": "A bit / slightly (before adj)",
					"notes": [
						"BEFORE the adjective: 'hơi đắt' (a bit expensive).",
						"Usually implies something is not ideal — mild negative connotation.",
						"Softest intensifier — like English 'a bit' or 'slightly'."
					]
				},
				"khá": {
					"meaning": "Quite / fairly (before adj)",
					"notes": [
						"BEFORE the adjective: 'khá tốt' (quite good).",
						"Slightly positive connotation — means 'reasonably' or 'decently'.",
						"Between 'hơi' (a bit) and 'rất' (very) in strength."
					]
				},
				"lắm": {
					"meaning": "Very (after adj, casual)",
					"notes": [
						"AFTER the adjective: 'đẹp lắm' (very beautiful).",
						"More casual and colloquial than 'rất'.",
						"Cannot be combined with 'rất' on the same adjective."
					]
				},
				"quá": {
					"meaning": "Too / so (after adj, emotional)",
					"notes": [
						"AFTER the adjective: 'đẹp quá!' (so beautiful!).",
						"Carries an exclamatory tone — like 'wow, so...'.",
						"Can also mean 'too much' (excessive): 'nóng quá' (too hot)."
					]
				},
				"cực kỳ": {
					"meaning": "Extremely (before adj)",
					"notes": [
						"Literally 'extreme' + 'limit' — the strongest common intensifier.",
						"BEFORE the adjective: 'cực kỳ quan trọng' (extremely important).",
						"More emphatic than 'rất'."
					]
				}
			},
			"examples": [
				{
					"vietnamese": "Phở rất ngon",
					"breakdown": {
						"Phở": { "type": "subject", "meaning": "phở" },
						"rất": { "type": "intensifier", "meaning": "very" },
						"ngon": { "type": "adjective", "meaning": "delicious" }
					},
					"english": "Phở is very delicious",
					"literalEnglish": "Phở very delicious"
				},
				{
					"vietnamese": "Hơi đắt",
					"breakdown": {
						"Hơi": { "type": "intensifier", "meaning": "a bit" },
						"đắt": { "type": "adjective", "meaning": "expensive" }
					},
					"english": "A bit expensive",
					"literalEnglish": "A-bit expensive"
				},
				{
					"vietnamese": "Món này khá ngon",
					"breakdown": {
						"Món": { "type": "classifier", "meaning": "(dish)" },
						"này": { "type": "demonstrative", "meaning": "this" },
						"khá": { "type": "intensifier", "meaning": "quite" },
						"ngon": { "type": "adjective", "meaning": "delicious" }
					},
					"english": "This dish is quite good",
					"literalEnglish": "(dish) this quite delicious"
				},
				{
					"vietnamese": "Cô ấy đẹp lắm",
					"breakdown": {
						"Cô ấy": { "type": "subject", "meaning": "she" },
						"đẹp": { "type": "adjective", "meaning": "beautiful" },
						"lắm": { "type": "intensifier", "meaning": "very" }
					},
					"english": "She is very beautiful",
					"literalEnglish": "She beautiful very"
				},
				{
					"vietnamese": "Trời nóng quá!",
					"breakdown": {
						"Trời": { "type": "subject", "meaning": "weather" },
						"nóng": { "type": "adjective", "meaning": "hot" },
						"quá": { "type": "intensifier", "meaning": "so/too" }
					},
					"english": "It's so hot!",
					"literalEnglish": "Weather hot so"
				},
				{
					"vietnamese": "Bài này cực kỳ khó",
					"breakdown": {
						"Bài": { "type": "classifier", "meaning": "(lesson)" },
						"này": { "type": "demonstrative", "meaning": "this" },
						"cực kỳ": { "type": "intensifier", "meaning": "extremely" },
						"khó": { "type": "adjective", "meaning": "difficult" }
					},
					"english": "This lesson is extremely difficult",
					"literalEnglish": "(lesson) this extremely difficult"
				}
			]
		}
	],
