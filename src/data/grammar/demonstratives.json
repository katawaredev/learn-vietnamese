{
	"introduction": {
		"title": "Vietnamese Demonstratives",
		"content": [
			"Demonstratives are 'pointing' words like 'this', 'that', 'here', and 'there'. Vietnamese uses a three-way system based on distance: near the speaker, near the listener, and far from both.",
			"Unlike English (this/that), Vietnamese also distinguishes 'over there' (kia) — a third level of distance for things visible but distant from both speakers.",
			"Demonstratives that modify a noun come AFTER it: 'con mèo này' = 'this cat' (literally: cat this). The classifier (con) is required because demonstratives count as quantifiers."
		]
	},
	"sections": [
		{
			"id": "noun-modifiers",
			"title": "This / That / Over There",
			"description": "Demonstratives that modify nouns — placed after the noun",
			"colorKey": "demonstrative",
			"words": {
				"này": {
					"meaning": "This (near speaker)",
					"notes": [
						"Refers to something close to the speaker.",
						"Always placed after the noun and its classifier: 'cái bàn này' (this table).",
						"Pronounced with a rising tone."
					]
				},
				"đó": {
					"meaning": "That (near listener)",
					"notes": [
						"Refers to something close to the listener but away from the speaker.",
						"Synonym 'ấy' is more common in writing or northern speech: 'cái bàn ấy'.",
						"Sometimes also means 'there' as a location word."
					]
				},
				"kia": {
					"meaning": "Over there (far from both)",
					"notes": [
						"Refers to something visible but far from both speaker and listener.",
						"Also works as a standalone place: 'Nhìn kia!' (Look over there!).",
						"No direct English equivalent — closest is 'yonder' or 'over there'."
					]
				},
				"nào": {
					"meaning": "Which / any",
					"notes": [
						"Placed after the noun to ask 'which one?'.",
						"Also means 'any' in certain contexts."
					]
				}
			},
			"examples": [
				{
					"vietnamese": "Con mèo này đẹp",
					"breakdown": {
						"Con": { "type": "classifier", "meaning": "(animal)" },
						"mèo": { "type": "noun", "meaning": "cat" },
						"này": { "type": "demonstrative", "meaning": "this" },
						"đẹp": { "type": "adjective", "meaning": "beautiful" }
					},
					"english": "This cat is beautiful",
					"literalEnglish": "(animal) cat this beautiful"
				},
				{
					"vietnamese": "Quyển sách đó của tôi",
					"breakdown": {
						"Quyển": { "type": "classifier", "meaning": "(book)" },
						"sách": { "type": "noun", "meaning": "book" },
						"đó": { "type": "demonstrative", "meaning": "that" },
						"của": { "type": "preposition", "meaning": "of" },
						"tôi": { "type": "object", "meaning": "me" }
					},
					"english": "That book is mine",
					"literalEnglish": "(book) book that of me"
				},
				{
					"vietnamese": "Người kia là ai?",
					"breakdown": {
						"Người": { "type": "classifier", "meaning": "(person)" },
						"kia": { "type": "demonstrative", "meaning": "over there" },
						"là": { "type": "verb", "meaning": "is" },
						"ai": { "type": "question", "meaning": "who" }
					},
					"english": "Who is that person over there?",
					"literalEnglish": "Person over-there is who"
				},
				{
					"vietnamese": "Bạn muốn cái nào?",
					"breakdown": {
						"Bạn": { "type": "subject", "meaning": "you" },
						"muốn": { "type": "verb", "meaning": "want" },
						"cái": { "type": "classifier", "meaning": "(thing)" },
						"nào": { "type": "demonstrative", "meaning": "which" }
					},
					"english": "Which one do you want?",
					"literalEnglish": "You want thing which"
				}
			]
		},
		{
			"id": "locations",
			"title": "Here / There / Where",
			"description": "Standalone location words — used as places, not noun modifiers",
			"colorKey": "location",
			"words": {
				"đây": {
					"meaning": "Here (this place)",
					"notes": [
						"Different from 'này' which modifies nouns — 'đây' is a place by itself."
					]
				},
				"đó": {
					"meaning": "There (that place)",
					"notes": [
						"Same word as the noun-modifier 'đó', but used as a place: 'ở đó' (over there).",
						"Refers to a place near the listener or already mentioned."
					]
				},
				"đâu": {
					"meaning": "Where",
					"notes": [
						"Also means 'nowhere' in negation: 'không đi đâu' (not going anywhere).",
						"Note: đó and kia also work as standalone places (see above)."
					]
				}
			},
			"examples": [
				{
					"vietnamese": "Đây là bạn tôi",
					"breakdown": {
						"Đây": { "type": "location", "meaning": "this/here" },
						"là": { "type": "verb", "meaning": "is" },
						"bạn": { "type": "noun", "meaning": "friend" },
						"tôi": { "type": "object", "meaning": "my" }
					},
					"english": "This is my friend",
					"literalEnglish": "Here is friend my"
				},
				{
					"vietnamese": "Tôi ở đây",
					"breakdown": {
						"Tôi": { "type": "subject", "meaning": "I" },
						"ở": { "type": "verb", "meaning": "be at" },
						"đây": { "type": "location", "meaning": "here" }
					},
					"english": "I'm here",
					"literalEnglish": "I be-at here"
				},
				{
					"vietnamese": "Bạn ở đâu?",
					"breakdown": {
						"Bạn": { "type": "subject", "meaning": "you" },
						"ở": { "type": "verb", "meaning": "be at" },
						"đâu": { "type": "location", "meaning": "where" }
					},
					"english": "Where are you?",
					"literalEnglish": "You be-at where"
				}
			]
		},
		{
			"id": "time-quantity",
			"title": "Time & Quantity",
			"description": "Demonstrative compounds for 'now', 'when', 'how much' — extremely common in daily speech",
			"colorKey": "demonstrative",
			"words": {
				"bây giờ": {
					"meaning": "Now",
					"notes": ["Literally 'this time' — the standard word for 'now'."]
				},
				"bao giờ": {
					"meaning": "When",
					"notes": ["Literally 'what time' — used to ask 'when?'."]
				},
				"bao nhiêu": {
					"meaning": "How much / how many",
					"notes": [
						"Literally 'what amount' — essential for shopping and counting."
					]
				},
				"bao lâu": {
					"meaning": "How long",
					"notes": ["Literally 'what duration'."]
				}
			},
			"examples": [
				{
					"vietnamese": "Bây giờ mấy giờ rồi?",
					"breakdown": {
						"Bây giờ": { "type": "demonstrative", "meaning": "now" },
						"mấy": { "type": "question", "meaning": "what (number)" },
						"giờ": { "type": "noun", "meaning": "hour" },
						"rồi": { "type": "particle", "meaning": "already" }
					},
					"english": "What time is it now?",
					"literalEnglish": "Now what hour already"
				},
				{
					"vietnamese": "Bao giờ bạn đi?",
					"breakdown": {
						"Bao giờ": { "type": "demonstrative", "meaning": "when" },
						"bạn": { "type": "subject", "meaning": "you" },
						"đi": { "type": "verb", "meaning": "go" }
					},
					"english": "When are you going?",
					"literalEnglish": "When you go"
				},
				{
					"vietnamese": "Bao nhiêu tiền?",
					"breakdown": {
						"Bao nhiêu": { "type": "demonstrative", "meaning": "how much" },
						"tiền": { "type": "noun", "meaning": "money" }
					},
					"english": "How much?",
					"literalEnglish": "How-much money"
				},
				{
					"vietnamese": "Bạn học bao lâu rồi?",
					"breakdown": {
						"Bạn": { "type": "subject", "meaning": "you" },
						"học": { "type": "verb", "meaning": "study" },
						"bao lâu": { "type": "demonstrative", "meaning": "how long" },
						"rồi": { "type": "particle", "meaning": "already" }
					},
					"english": "How long have you been studying?",
					"literalEnglish": "You study how-long already"
				}
			]
		},
		{
			"id": "manner",
			"title": "Like This / Like That",
			"description": "Saying 'so', 'like this', or 'in that way'",
			"colorKey": "demonstrative",
			"words": {
				"thế": {
					"meaning": "So / like that",
					"notes": [
						"Used at the end of a sentence to mean 'so' or 'like that'."
					]
				}
			},
			"examples": [
				{
					"vietnamese": "Đừng làm thế",
					"breakdown": {
						"Đừng": { "type": "negation", "meaning": "don't" },
