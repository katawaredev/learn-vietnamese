					"literalEnglish": "They already go already",
					"notes": "đã + rồi — very common double emphasis"
				},
				{
					"vietnamese": "Em đã ăn cơm chưa?",
					"breakdown": {
						"Em": {
							"type": "subject",
							"meaning": "you (younger)"
						},
						"đã": {
							"type": "tense-marker",
