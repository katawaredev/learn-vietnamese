		{
			"id": "future",
			"title": "Future Tense",
			"description": "Actions that will happen",
			"markers": {
				"sẽ": {
					"meaning": "Will (future)",
					"notes": [
						"Standard future tense marker — placed before the verb",
						"Used for plans, predictions, and promises: 'Tôi sẽ đi' (I will go)",
						"Can be omitted when future is clear from context: 'Ngày mai tôi đi Hà Nội' (Tomorrow I go to Hanoi)",
						"In questions: 'Bạn sẽ làm gì?' (What will you do?)"
					]
				},
				"sắp": {
					"meaning": "About to (near future)",
					"notes": [
						"Indicates action is about to happen soon — more immediate than 'sẽ'",
						"Implies imminence: 'Trời sắp mưa' (It's about to rain)",
						"Cannot be used for distant future — use 'sẽ' instead",
						"Often carries a sense of urgency or warning: 'Sắp trễ rồi!' (We're about to be late!)"
					]
				}
			},
			"examples": [
