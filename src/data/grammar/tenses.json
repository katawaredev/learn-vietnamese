						}
					},
					"english": "I DID tell him already",
					"literalEnglish": "I DID say to him already",
					"notes": "Emphatic 'có' combined with 'rồi' — strong assertion"
				},
				{
					"vietnamese": "Họ đã đi rồi",
					"breakdown": {
						"Họ": {
							"type": "subject",
							"meaning": "they"
						},
						"đã": {
							"type": "tense-marker",
							"meaning": "already (past)"
