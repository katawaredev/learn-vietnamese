		{
			"id": "recent-past",
			"title": "Recent Past",
			"description": "Actions that just happened",
			"markers": {
				"mới": {
					"meaning": "Just (recently)",
					"notes": [
						"Indicates action was completed very recently — placed before the verb",
						"Most common in everyday speech: 'Tôi mới ăn' (I just ate)",
						"'Vừa mới' is the more formal/emphatic variant: 'Tôi vừa mới đến' (I just arrived)",
						"'Vừa' alone also works but is less common than 'mới' in casual speech",
						"Often combined with 'xong' (finished) for completion: 'Tôi mới ăn xong' (I just finished eating)"
					]
				}
			},
