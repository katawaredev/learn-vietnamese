{
	"introduction": {
		"title": "Vietnamese Tense Markers",
		"content": [
			"Unlike English, Vietnamese verbs never conjugate. Instead, Vietnamese uses tense markers (particles) that are placed before or after the verb to indicate when an action occurs.",
			"The key difference: English changes the verb itself (go → went → will go), while Vietnamese keeps the verb unchanged and adds a marker word.",
			"Many tense markers are optional when context makes the timing clear. However, using them adds clarity and emphasis.",
			"Important: 'rồi' is the ONLY common tense marker that comes AFTER the verb. All others come BEFORE."
		]
	},
	"sections": [
		{
			"id": "past",
			"title": "Past Tense",
			"description": "Markers that indicate completed actions in the past",
			"markers": {
				"đã": {
					"meaning": "Already / completed action",
					"notes": [
						"Most common past tense marker — placed before the verb",
						"Often combined with 'rồi' after the verb for stronger emphasis: 'Tôi đã ăn rồi' (I already ate)",
						"In questions, 'đã...chưa' asks if something has happened yet: 'Bạn đã ăn chưa?' (Have you eaten yet?)",
						"Can be omitted when context is clear: 'Hôm qua tôi ăn phở' (Yesterday I ate phở)"
					]
				},
				"có": {
					"meaning": "Did (emphatic past)",
					"notes": [
						"Emphatic — used to contradict or strongly affirm: 'Tôi CÓ nói!' (I DID say it!)",
						"Placed before the verb, often stressed in speech",
						"Also used in yes-no questions: 'Bạn có đi không?' (Did you go?)",
						"Different from 'có' meaning 'to have' — context determines meaning"
					]
				},
				"rồi": {
					"meaning": "Already (completed)",
					"notes": [
						"Unique position: placed AFTER the verb (all other markers go before)",
						"Can be used alone: 'Tôi ăn rồi' (I ate already) or with 'đã': 'Tôi đã ăn rồi'",
						"Also used to signal state change: 'Tôi hiểu rồi' (I understand now / I got it)",
						"Very common in everyday speech — often the simplest way to express past"
					]
				}
			},
			"examples": [
				{
					"vietnamese": "Tôi đã học tiếng Việt",
					"breakdown": {
						"Tôi": {
							"type": "subject",
							"meaning": "I"
						},
						"đã": {
							"type": "tense-marker",
							"meaning": "already (past)"
						},
						"học": {
							"type": "verb",
							"meaning": "study"
						},
						"tiếng Việt": {
							"type": "object",
							"meaning": "Vietnamese"
						}
					},
					"english": "I studied Vietnamese",
					"literalEnglish": "I already study Vietnamese",
					"notes": "Standard past tense with đã"
				},
				{
					"vietnamese": "Tôi có nói với anh ấy rồi",
