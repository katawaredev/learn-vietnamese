{
	"introduction": {
		"title": "Vietnamese Comparatives & Superlatives",
		"content": [
			"Unlike English (tall → taller → tallest), Vietnamese adjectives never change form. Instead, Vietnamese uses particles after the adjective to express comparison.",
			"This makes Vietnamese comparatives simpler and more predictable: just learn the particles (hơn, bằng, nhất) and their positions.",
			"The basic pattern is always: ADJECTIVE + PARTICLE + (comparison/scope)."
		]
	},
	"sections": [
		{
			"id": "comparative",
			"title": "More Than / Less Than",
			"description": "Comparing two things — A + adjective + 'hơn' + B",
			"colorKey": "comparative",
			"words": {
				"hơn": {
					"meaning": "More than",
					"notes": [
						"Always placed AFTER the adjective.",
						"The thing being compared comes after: A + adj + hơn + B.",
						"Taller: ~~hơn cao~~ __cao hơn__ (marker goes after the adjective, not before)."
					]
				},
				"hơn nhiều": {
					"meaning": "Much more than",
					"notes": [
						"Literally 'more' + 'much' — 'nhiều' intensifies the comparison."
					]
				},
				"hơn hẳn": {
					"meaning": "Far more than",
					"notes": [
						"Literally 'more' + 'clearly' — implies an obvious, undeniable gap."
					]
				},
				"kém": {
					"meaning": "Less than (inferior)",
					"notes": [
						"Placed AFTER the adjective, like hơn: 'cao kém' (less tall).",
						"Can sound blunt — 'không...bằng' is softer and more common."
					]
				},
				"không ... bằng": {
					"meaning": "Not as ... as",
					"notes": [
						"Literally 'not' + 'equal' — the natural way to say 'less than'.",
						"Pattern: A + không + adj + bằng + B."
					]
				}
			},
			"examples": [
				{
					"vietnamese": "Anh ấy cao hơn tôi",
					"breakdown": {
						"Anh ấy": { "type": "subject", "meaning": "he" },
						"cao": { "type": "adjective", "meaning": "tall" },
						"hơn": { "type": "comparative", "meaning": "more than" },
						"tôi": { "type": "object", "meaning": "me" }
					},
					"english": "He is taller than me",
					"literalEnglish": "He tall more me"
				},
				{
					"vietnamese": "Anh ấy giàu hơn tôi nhiều",
					"breakdown": {
						"Anh ấy": { "type": "subject", "meaning": "he" },
						"giàu": { "type": "adjective", "meaning": "rich" },
						"hơn": { "type": "comparative", "meaning": "more than" },
						"tôi": { "type": "object", "meaning": "me" },
						"nhiều": { "type": "intensifier", "meaning": "much" }
					},
					"english": "He is much richer than me",
					"literalEnglish": "He rich more me much"
				},
				{
					"vietnamese": "Cái này tốt hơn hẳn cái kia",
					"breakdown": {
						"Cái này": { "type": "subject", "meaning": "this one" },
						"tốt": { "type": "adjective", "meaning": "good" },
						"hơn hẳn": { "type": "comparative", "meaning": "far more than" },
						"cái kia": { "type": "object", "meaning": "that one" }
					},
					"english": "This is far better than that",
					"literalEnglish": "This good more-far that"
				},
				{
					"vietnamese": "Tôi cao kém anh ấy",
					"breakdown": {
						"Tôi": { "type": "subject", "meaning": "I" },
						"cao": { "type": "adjective", "meaning": "tall" },
						"kém": { "type": "comparative", "meaning": "less than" },
						"anh ấy": { "type": "object", "meaning": "him" }
					},
					"english": "I am less tall than him",
					"literalEnglish": "I tall less him"
				},
				{
					"vietnamese": "Tôi không cao bằng anh ấy",
					"breakdown": {
						"Tôi": { "type": "subject", "meaning": "I" },
						"không": { "type": "negation", "meaning": "not" },
						"cao": { "type": "adjective", "meaning": "tall" },
						"bằng": { "type": "comparative", "meaning": "as...as" },
						"anh ấy": { "type": "object", "meaning": "him" }
					},
					"english": "I'm not as tall as him",
					"literalEnglish": "I not tall equal him"
				}
			]
		},
		{
			"id": "equality",
			"title": "Equal / As ... As",
			"description": "Saying two things are equal — A + adjective + 'bằng' + B",
			"colorKey": "comparative",
			"words": {
				"bằng": {
					"meaning": "Equal to / as ... as",
					"notes": [
						"Used for measurable equality: height, age, size, quantity.",
						"Comes after the adjective, before the second item."
					]
				},
				"giống như": {
					"meaning": "Same as / like",
					"notes": [
						"Literally 'resemble' + 'like' — used for overall similarity, not exact measurement.",
						"Can compare things, people, or situations."
					]
				},
				"như": {
					"meaning": "Like / as (figurative)",
					"notes": [
						"More poetic and figurative than 'bằng'.",
						"Often used in idioms and similes."
					]
				}
			},
			"examples": [
				{
					"vietnamese": "Em cao bằng anh",
					"breakdown": {
						"Em": { "type": "subject", "meaning": "I (younger)" },
						"cao": { "type": "adjective", "meaning": "tall" },
						"bằng": { "type": "comparative", "meaning": "equal to" },
						"anh": { "type": "object", "meaning": "you (older)" }
					},
					"english": "I am as tall as you",
					"literalEnglish": "I tall equal you"
				},
				{
					"vietnamese": "Cái này giống như cái kia",
					"breakdown": {
						"Cái này": { "type": "subject", "meaning": "this one" },
						"giống như": { "type": "comparative", "meaning": "same as" },
						"cái kia": { "type": "object", "meaning": "that one" }
					},
					"english": "This is the same as that",
					"literalEnglish": "This same-as that"
				},
				{
					"vietnamese": "Cô ấy đẹp như tiên",
					"breakdown": {
						"Cô ấy": { "type": "subject", "meaning": "she" },
						"đẹp": { "type": "adjective", "meaning": "beautiful" },
						"như": { "type": "comparative", "meaning": "like" },
						"tiên": { "type": "object", "meaning": "fairy" }
					},
					"english": "She is as beautiful as a fairy",
					"literalEnglish": "She beautiful like fairy"
				}
			]
		},
		{
			"id": "superlative",
			"title": "Most (Superlative)",
			"description": "Saying something is the most — adjective + 'nhất'",
			"colorKey": "superlative",
			"words": {
				"nhất": {
					"meaning": "Most / -est",
					"notes": [
						"Placed AFTER the adjective.",
						"Works for any adjective — no other changes needed.",
						"Most beautiful: ~~đẹp hơn nhất~~ __đẹp nhất__ (don't mix hơn and nhất — pick one)."
					]
				}
			},
			"examples": [
				{
					"vietnamese": "Phim này hay nhất",
					"breakdown": {
						"Phim": { "type": "noun", "meaning": "movie" },
						"này": { "type": "demonstrative", "meaning": "this" },
						"hay": { "type": "adjective", "meaning": "good/interesting" },
						"nhất": { "type": "superlative", "meaning": "most" }
					},
					"english": "This movie is the best",
					"literalEnglish": "Movie this good most"
				},
				{
					"vietnamese": "Cô ấy đẹp nhất trong lớp",
					"breakdown": {
						"Cô ấy": { "type": "subject", "meaning": "she" },
						"đẹp": { "type": "adjective", "meaning": "beautiful" },
						"nhất": { "type": "superlative", "meaning": "most" },
						"trong": { "type": "preposition", "meaning": "in" },
						"lớp": { "type": "noun", "meaning": "class" }
					},
					"english": "She is the most beautiful in class",
					"literalEnglish": "She beautiful most in class"
				}
			]
		},
		{
			"id": "special-patterns",
			"title": "Special Patterns",
			"description": "Common comparison idioms — 'càng' A + 'càng' B",
			"colorKey": "comparative",
			"words": {
				"càng ... càng": {
					"meaning": "The more ... the more",
					"notes": [
						"Literally 'more' + 'more' — shows correlation between two changing qualities.",
						"Pattern: càng + A + càng + B."
					]
				},
				"ngày càng": {
					"meaning": "Increasingly / more and more",
					"notes": [
						"Expresses gradual change over time.",
						"Literally 'day more' — each day it increases."
					]
				},
				"thích ... hơn": {
					"meaning": "Prefer ... to",
					"notes": ["Literally 'like' + 'more' — pattern: thích + A + hơn + B."]
				}
			},
			"examples": [
				{
					"vietnamese": "Càng học càng khó",
					"breakdown": {
						"Càng": { "type": "comparative", "meaning": "the more" },
						"học": { "type": "verb", "meaning": "study" },
						"càng": { "type": "comparative", "meaning": "the more" },
						"khó": { "type": "adjective", "meaning": "difficult" }
					},
					"english": "The more I study, the harder it gets",
					"literalEnglish": "More study more difficult"
				},
				{
					"vietnamese": "Càng sớm càng tốt",
					"breakdown": {
						"Càng": { "type": "comparative", "meaning": "the more" },
						"sớm": { "type": "adjective", "meaning": "early" },
						"càng": { "type": "comparative", "meaning": "the more" },
						"tốt": { "type": "adjective", "meaning": "good" }
					},
					"english": "As soon as possible",
					"literalEnglish": "More early more good"
				},
				{
					"vietnamese": "Thời tiết ngày càng nóng",
					"breakdown": {
						"Thời tiết": { "type": "subject", "meaning": "weather" },
						"ngày càng": { "type": "comparative", "meaning": "increasingly" },
						"nóng": { "type": "adjective", "meaning": "hot" }
					},
					"english": "The weather is getting hotter and hotter",
					"literalEnglish": "Weather day-more hot"
				},
				{
					"vietnamese": "Tôi thích cà phê hơn trà",
					"breakdown": {
						"Tôi": { "type": "subject", "meaning": "I" },
						"thích": { "type": "verb", "meaning": "like" },
						"cà phê": { "type": "object", "meaning": "coffee" },
						"hơn": { "type": "comparative", "meaning": "more than" },
						"trà": { "type": "object", "meaning": "tea" }
					},
					"english": "I prefer coffee to tea",
					"literalEnglish": "I like coffee more tea"
				}
			]
		}
	]
}
