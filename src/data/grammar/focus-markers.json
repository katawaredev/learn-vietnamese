{
	"introduction": {
		"title": "Vietnamese Focus Markers",
		"content": [
			"Focus markers highlight or emphasize a specific part of a sentence — like English using stress ('It was JOHN who broke it') or 'as for...' constructions.",
			"Vietnamese has dedicated words for this: 'thì' marks topic-comment boundaries, 'là' acts as a focus copula, and 'chính' means 'exactly/precisely' to pinpoint the focused element.",
			"These are subtle but important — they let you control which information sounds new, contrasted, or emphasized without changing word order."
		]
	},
	"sections": [
		{
			"id": "topic-comment",
			"title": "Topic Marking (thì)",
			"description": "Marking what the sentence is 'about' before commenting on it",
			"colorKey": "marker",
			"words": {
				"thì": {
					"meaning": "As for / then (topic marker)",
					"notes": [
						"Placed after the topic to introduce a comment about it.",
						"Often signals contrast with what someone else thinks or does.",
						"Different from 'thì' in conditionals ('nếu...thì'), though related."
					]
				}
			},
			"examples": [
				{
					"vietnamese": "Tôi thì thích phở",
					"breakdown": {
						"Tôi": { "type": "topic", "meaning": "I" },
						"thì": { "type": "marker", "meaning": "as for" },
						"thích": { "type": "verb", "meaning": "like" },
						"phở": { "type": "object", "meaning": "phở" }
					},
					"english": "As for me, I like phở",
					"literalEnglish": "I as-for like phở"
				},
				{
					"vietnamese": "Hôm nay thì trời đẹp",
					"breakdown": {
						"Hôm nay": { "type": "topic", "meaning": "today" },
						"thì": { "type": "marker", "meaning": "as for" },
						"trời": { "type": "subject", "meaning": "weather" },
						"đẹp": { "type": "adjective", "meaning": "nice" }
					},
					"english": "Today, the weather is nice",
					"literalEnglish": "Today as-for weather nice"
				}
			]
		},
		{
			"id": "focus-copula",
			"title": "Focus Copula (là)",
			"description": "Highlighting a specific element with 'là'",
			"colorKey": "marker",
			"words": {
				"là": {
					"meaning": "Is / it is (focus)",
					"notes": [
						"Normally 'là' means 'to be' for identity.",
						"As a focus marker, it isolates the highlighted element.",
						"Carries emphasis like English 'it is X that...'.",
						"Often used in answers to highlight the new information."
					]
				}
			},
			"examples": [
				{
					"vietnamese": "Cái tôi muốn là phở",
					"breakdown": {
						"Cái": { "type": "classifier", "meaning": "(thing)" },
						"tôi": { "type": "subject", "meaning": "I" },
						"muốn": { "type": "verb", "meaning": "want" },
						"là": { "type": "marker", "meaning": "is (focus)" },
						"phở": { "type": "object", "meaning": "phở" }
					},
					"english": "What I want is phở",
					"literalEnglish": "Thing I want is phở"
				},
				{
					"vietnamese": "Người gọi điện là anh Nam",
					"breakdown": {
						"Người": { "type": "classifier", "meaning": "person" },
						"gọi điện": { "type": "verb", "meaning": "call" },
						"là": { "type": "marker", "meaning": "is (focus)" },
						"anh Nam": { "type": "object", "meaning": "Nam (older brother)" }
					},
					"english": "The person who called is Nam",
					"literalEnglish": "Person call is brother Nam"
				}
			]
		},
		{
			"id": "emphatic",
			"title": "Emphatic Particles (chính / ngay)",
			"description": "Pinpointing exactly the right element",
			"colorKey": "marker",
			"words": {
				"chính": {
					"meaning": "Exactly / precisely",
					"notes": [
						"Placed before the noun to pinpoint exactly who or what.",
						"Adds strong identification — 'this is the one'.",
						"Common in answers and corrections."
					]
				},
				"mới": {
					"meaning": "Is the real / actual one",
					"notes": [
						"Used with 'là' to assert the true or correct identity.",
						"Implies contrast — correcting a wrong assumption.",
						"Different from 'mới' meaning 'new' or 'just (recently)' — context decides."
					]
				},
				"ngay": {
					"meaning": "Right (here/then) / immediately",
					"notes": [
						"Marks immediacy or precise location.",
						"Often combines with location words."
					]
				},
				"cái": {
					"meaning": "Emphasis / contrastive focus",
					"notes": [
						"Placed before the classifier to add emphasis: 'cái con chó này' (this very dog).",
						"Different from the classifier 'cái' for objects — here it works with ANY classifier.",
						"Pattern: cái + classifier + noun. Can sound dismissive or admiring depending on tone."
					]
				}
			},
			"examples": [
				{
					"vietnamese": "Chính tôi đã làm",
					"breakdown": {
						"Chính": { "type": "marker", "meaning": "exactly" },
						"tôi": { "type": "subject", "meaning": "I" },
						"đã": { "type": "tense-marker", "meaning": "did" },
						"làm": { "type": "verb", "meaning": "do" }
					},
					"english": "I myself did it",
					"literalEnglish": "Exactly I did do"
				},
				{
					"vietnamese": "Nó ở ngay đây",
					"breakdown": {
						"Nó": { "type": "subject", "meaning": "it" },
						"ở": { "type": "verb", "meaning": "be at" },
						"ngay": { "type": "marker", "meaning": "right" },
						"đây": { "type": "location", "meaning": "here" }
					},
					"english": "It's right here",
					"literalEnglish": "It be-at right here"
				},
				{
					"vietnamese": "Làm ngay!",
					"breakdown": {
						"Làm": { "type": "verb", "meaning": "do" },
						"ngay": { "type": "marker", "meaning": "immediately" }
					},
					"english": "Do it right now!",
					"literalEnglish": "Do immediately"
				},
				{
					"vietnamese": "Anh ấy mới là sếp",
					"breakdown": {
						"Anh ấy": { "type": "subject", "meaning": "he" },
						"mới": { "type": "marker", "meaning": "is the real" },
						"là": { "type": "marker", "meaning": "is" },
						"sếp": { "type": "object", "meaning": "boss" }
					},
					"english": "He is the actual boss",
					"literalEnglish": "He real-is boss",
					"notes": "Implies: someone else was mistakenly thought to be the boss"
				},
				{
					"vietnamese": "Cái con mèo này dễ thương lắm",
					"breakdown": {
						"Cái": { "type": "marker", "meaning": "(emphasis)" },
						"con": { "type": "classifier", "meaning": "[CL]" },
						"mèo": { "type": "object", "meaning": "cat" },
						"này": { "type": "demonstrative", "meaning": "this" },
						"dễ thương": { "type": "adjective", "meaning": "cute" },
						"lắm": { "type": "adverb", "meaning": "very" }
					},
					"english": "This cat is SO cute",
					"literalEnglish": "(emphasis) [CL] cat this cute very",
					"notes": "'cái' before the classifier 'con' adds emphasis — not acting as a classifier itself"
				}
			]
		}
	]
}
